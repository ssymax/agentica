# LLM API configuration
LLM_BASE_URL=          # required — OpenAI-compatible base URL, no trailing slash
LLM_API_KEY=           # required 
LLM_MODEL=             # required — discover via GET /v1/models (see api.http)

# PostgreSQL — only this URL matters; the db service is opt-in via the "local" profile.
# Local:  docker compose --profile local up
# Remote: set the URL below and run docker compose up 
DATABASE_URL=postgresql://helpdesk:helpdesk@db:5432/helpdesk

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Local app ports and dev proxy
FRONTEND_PORT=3000
BACKEND_PORT=8000
VITE_API_PROXY_TARGET=http://localhost:8000
